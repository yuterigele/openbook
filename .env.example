# Copy this file to .env and fill in your values.
# The .env file is loaded automatically at startup (see chatmodel/envfile.go).
# Real shell environment variables always take precedence over .env values.

# ====== LLM (DeepSeek / OpenAI / Volcengine Ark) ======
# DeepSeek only supports Chat Completions API (/chat/completions).
# IMPORTANT: DeepSeek does NOT support the Responses API, so you MUST set
# MESSAGE_KIND=message to use openai.NewChatModel instead of agenticopenai.
MESSAGE_KIND=message
MODEL_TYPE=
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=sk-your-deepseek-api-key
OPENAI_MODEL=deepseek-chat

# --- OpenAI (default) ---
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o-mini

# --- Volcengine Ark ---
# MODEL_TYPE=ark
# ARK_API_KEY=
# ARK_MODEL=
# ARK_BASE_URL=

# ====== MySQL（PRD §11.1 P0：持久化 + MsgId 唯一索引做幂等去重） ======
# Either MYSQL_DSN or MYSQL_HOST/PORT/USER/PASS/DB
# MYSQL_DSN=user:pass@tcp(127.0.0.1:3306)/chatwitheino?charset=utf8mb4&parseTime=True&loc=Local
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASS=root
MYSQL_DB=chatwitheino

# ====== Redis（PRD §3.3：分布式锁防并发预约冲突） ======
# 没接 Redis 时会降级放行（生产强烈建议接）
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# ====== 企业微信 ======
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=
# 微信客服链接（从管理后台「微信客服 → 客服账号 → 获取链接」获取）
WECOM_KF_LINK=

# ====== 服务端口 ======
PORT=38080

# ====== 商户后台（PRD §11.2 P1，多店版） ======
# JWT 签名密钥（生产必须改成强随机字符串）
JWT_SECRET=9sK7pR2zG8dF5bQ0xT3nL6cV1mJ4hY7aS2dP9fB3gN6kZ0rX5tC8vM2jH1yS7lD4qW0zF6bR9nG3xT5cV8mJ2hY7sK1dP4fB9gN6kZ0rX

# 旧版兼容：单一 ADMIN_TOKEN，非空时作为 fallback 鉴权（新部署可留空）
ADMIN_TOKEN=

# ====== D+15 使用报告邮件（PRD §11.11 v4.2） ======
# 收件人列表（逗号分隔），空时 D+15 只发微信不发邮件
# REPORT_TO=owner@shop.com,partner@shop.com

# SMTP 配置（Gmail / QQ 企业邮箱 / 163 / 自建 SMTP 都行）
# Gmail：SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, 用应用专用密码（不是登录密码）
# QQ ：SMTP_HOST=smtp.qq.com, SMTP_PORT=465
# 163：SMTP_HOST=smtp.163.com, SMTP_PORT=465
# SMTP_HOST=
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_FROM_NAME=美发店 AI Agent

# 默认店铺配置（首次启动会种子进 shops 表 + 建 admin/admin123 账号）
DEFAULT_SHOP_ID=default
DEFAULT_SHOP_NAME=默认理发店
DEFAULT_SHOP_ADDRESS=请到 .env 配置
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# ====== 可选：观测 ======
# COZELOOP_WORKSPACE_ID=
# COZELOOP_API_TOKEN=

# ====== 可选：会话存储路径（本地开发可不动） ======
# WORKSPACE_DIR=./data/workspace
# EINO_EXT_SKILLS_DIR=