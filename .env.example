# 主模型降级链：DeepSeek → OpenAI → Ark → Stub
MESSAGE_KIND=message
MODEL_TYPE=
OPENBOOK_LLM_CHAIN=deepseek,openai,ark

DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# 小模型：仅做分类，异常时回退规则
SMALL_MODEL_ENABLED=0
SMALL_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SMALL_MODEL_API_KEY=your-dashscope-api-key
SMALL_MODEL_NAME=qwen-flash

# --- Volcengine Ark ---
ARK_API_KEY=your-ark-api-key
ARK_MODEL=doubao-seed-2-0-lite-260215
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ====== MySQL（PRD §11.1 P0：持久化 + MsgId 唯一索引做幂等去重） ======
# Either MYSQL_DSN or MYSQL_HOST/PORT/USER/PASS/DB
MYSQL_DSN=chatwitheino:chatwitheino@tcp(127.0.0.1:3306)/chatwitheino?charset=utf8mb4&parseTime=True&loc=Local
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=chatwitheino
MYSQL_PASS=chatwitheino
MYSQL_DB=chatwitheino
# Docker Compose：应用使用专用账号而非 root；本地 Demo 也请替换成随机密码。
# 仅使用字母、数字、-、_，避免 Compose 初始化脚本的转义歧义。
MYSQL_APP_PASSWORD=replace-with-a-random-local-password

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
# 预约锁初始 TTL；持锁期间看门狗每隔约 TTL/3 自动续租。
APPOINTMENT_LOCK_TTL=10s

# 企业微信（凭据由 shops 表管理）
WECOM_CALLBACK_URL=

# 服务
PORT=38080
# 本机性能分析端点（pprof + trace），默认 127.0.0.1:6060；不要暴露到公网
# PPROF_ADDR=127.0.0.1:6060

# Agent
AGENT_MAX_EXECUTION_SECONDS=60
# 平台 Agent 运行监控：5 分钟内累计 Token 达到该阈值时显示异常告警。
# 仅 platform_admin 可在「Agent 运行监控」页面查看；默认 1000000。
LLM_TOKEN_ALERT_5M=1000000
# 顾客输入相关性/风险门槛：分数小于等于该值时不进入 Agent 或预约工具。
# 默认 -2；数值越大越严格。短问候和不完整预约请求仍会放行。
USER_INPUT_TRUST_THRESHOLD=-2

# 管理端
JWT_SECRET=replace-with-a-long-random-secret-before-production

# 旧版兼容：单一 ADMIN_TOKEN，非空时作为 fallback 鉴权（新部署可留空）
ADMIN_TOKEN=

# ====== D+15 使用报告邮件（PRD §11.11 v4.2） ======
# 收件人列表（逗号分隔），空时 D+15 只发微信不发邮件
# REPORT_TO=owner@shop.com,partner@shop.com

# ====== 周报邮件（PRD §8.2 / §11.12 v4.3 + v4.5 跨店） ======
# 单店周报：每周一 9:00 给所有店铺各发一封（沿用 D+15 同 SMTP）
# 留空时单店周报不发邮件（仅写埋点）
# REPORT_TO=owner@shop.com

# 跨店汇总周报：每周一 9:00 额外发一封给连锁 owner（v4.5 增量）
# 留空时跨店周报不发邮件（仅写埋点）；与单店 REPORT_TO 完全独立
# CHAIN_REPORT_TO=chain-owner@group.com

# SMTP 配置（Gmail / QQ 企业邮箱 / 163 / 自建 SMTP 都行）
# Gmail：SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, 用应用专用密码（不是登录密码）
# QQ ：SMTP_HOST=smtp.qq.com, SMTP_PORT=465
# 163：SMTP_HOST=smtp.163.com, SMTP_PORT=465
# SMTP_HOST=
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_FROM_NAME=美发店 AI Agent

# 默认店铺配置（首次启动会种子进 shops 表 + 建后台账号）
# v4.14：店铺地址不再走 .env，请在商户后台「店铺设置」页面手填
DEFAULT_SHOP_ID=default
DEFAULT_SHOP_NAME=默认理发店
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me-before-exposing
DEFAULT_PLATFORM_ADMIN_USERNAME=platform
DEFAULT_PLATFORM_ADMIN_PASSWORD=change-me-before-exposing

# ====== 可选：观测 ======
# COZELOOP_WORKSPACE_ID=
# COZELOOP_API_TOKEN=

# ====== 可选：会话存储路径（本地开发可不动） ======
# WORKSPACE_DIR=./data/workspace
# EINO_EXT_SKILLS_DIR=

# 运行策略
APP_ENV=production
REDIS_REQUIRED=1
